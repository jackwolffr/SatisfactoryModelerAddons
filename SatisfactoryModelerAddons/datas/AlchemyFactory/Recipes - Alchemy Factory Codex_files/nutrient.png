</style></head> <body data-astro-cid-37fxchfa> <script type="text/javascript" src="https://storage.ko-fi.com/cdn/widget/Widget_2.js"></script> <script slot="head">
    // expose a simple global flag for the rest of the page
    window.__AFC_AD_FREE__ = document.cookie.includes("afc_ad_free=true");
		console.log("Ad-free mode:", window.__AFC_AD_FREE__);
    if (!window.__AFC_AD_FREE__) {
      // Load AdSense script only for non-ad-free users
      const s = document.createElement("script");
      s.async = true;
      s.src = "https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js";
			s.onload = () => console.log("AdSense script loaded");
