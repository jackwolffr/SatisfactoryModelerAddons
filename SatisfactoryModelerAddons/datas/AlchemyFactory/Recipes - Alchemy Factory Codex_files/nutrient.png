      s.crossOrigin = "anonymous";
      document.head.appendChild(s);
    }
  </script> <script slot="head">
		document.addEventListener('DOMContentLoaded', () => {
			const banner = document.getElementById('lang-suggest-banner');
			if (!banner) return;
			const currentLang = (banner.dataset.currentLang || '').toLowerCase();
			const browserLang = (navigator.language || '').toLowerCase().substring(0, 2);
			const supportedLangs = new Set(['en', 'ja', 'de', 'fr']);
			if (!supportedLangs.has(browserLang) || !currentLang || browserLang === currentLang) {
				banner.style.display = 'none';
				return;
			}

			const link = document.getElementById('lang-suggest-link');
			if (!link) return;
			const dismissBtn = document.getElementById('dismiss-lang-suggest');
			const storageKey = `dismiss-lang-suggest`;
			if (localStorage.getItem(storageKey) === 'true') {
				banner.style.display = 'none';
				return;
			}

			const path = window.location.pathname;
			const stripLangPrefix = (value) => {
				if (value === '/ja' || value === '/de' || value === '/fr') return '/';
				if (value.startsWith('/ja/')) return value.slice(3);
				if (value.startsWith('/de/')) return value.slice(3);
				if (value.startsWith('/fr/')) return value.slice(3);
				return value;
			};
			let targetPath = path;
			if (browserLang === 'ja') {
				const basePath = stripLangPrefix(path);
				targetPath = basePath === '/' ? '/ja' : `/ja${basePath}`;
			} else if (browserLang === 'de') {
				const basePath = stripLangPrefix(path);
				targetPath = basePath === '/' ? '/de' : `/de${basePath}`;
			} else if (browserLang === 'fr') {
				const basePath = stripLangPrefix(path);
				targetPath = basePath === '/' ? '/fr' : `/fr${basePath}`;
			} else if (browserLang === 'en') {
				targetPath = stripLangPrefix(path);
			}

			if (targetPath === path) {
				banner.style.display = 'none';
				return;
			}

			const cap = (lang) => `${lang.charAt(0).toUpperCase()}${lang.slice(1)}`;
			const currentCap = cap(currentLang);
			const targetCap = cap(browserLang);
			const templateCurrent = banner.dataset[`template${currentCap}`] || '';
			const templateTarget = banner.dataset[`template${targetCap}`] || '';
			const targetNameInCurrent = banner.dataset[`name${targetCap}In${currentCap}`] || browserLang.toUpperCase();
			const targetNameInTarget = banner.dataset[`name${targetCap}In${targetCap}`] || browserLang.toUpperCase();
			const targetFlag = banner.dataset[`flag${targetCap}`] || '';
			if (!templateCurrent || !templateTarget) {
				banner.style.display = 'none';
				return;
			}

			const targetPhrase = templateTarget.replace('{language}', targetNameInTarget);
			const currentPhrase = templateCurrent.replace('{language}', targetNameInCurrent);
			link.href = `${targetPath}${window.location.search}${window.location.hash}`;
			link.textContent = `${targetFlag ? `${targetFlag} ` : ''}${targetPhrase} / ${currentPhrase}`;
			if (dismissBtn) {
				const dismissCurrent = banner.dataset[`dismiss${currentCap}`] || '';
				const dismissTarget = banner.dataset[`dismiss${targetCap}`] || '';
				dismissBtn.textContent = dismissCurrent && dismissTarget
					? `${dismissCurrent} / ${dismissTarget}`
					: (dismissCurrent || dismissTarget || dismissBtn.textContent);
			}
			banner.style.display = 'flex';

			if (dismissBtn) {
				dismissBtn.addEventListener('click', () => {
					localStorage.setItem(storageKey, 'true');
					banner.style.display = 'none';
				});
			}
		});
	</script> <div class="layout-container" data-astro-cid-kavczoxm> <aside class="sidebar" data-astro-cid-kavczoxm> <a href="/" class="logo-link" data-astro-cid-kavczoxm> <img src="/alchemy-factory-codex.png" alt="Alchemy Factory Codex" class="logo-image" data-astro-cid-kavczoxm> </a> <div class="sidebar-links" data-astro-cid-kavczoxm> <div data-astro-cid-kavczoxm> <div class="sidebar-link-wrapper" data-astro-cid-kavczoxm> <a href="/items" class="sidebar-link with-submenu" data-astro-cid-kavczoxm> Items </a> <button class="submenu-toggle" data-submenu="items" aria-label="Toggle submenu" data-astro-cid-kavczoxm> <span class="toggle-icon" data-astro-cid-kavczoxm>+</span> </button> </div> <div class="submenu" data-submenu-content="items" data-astro-cid-kavczoxm> <a href="/items/all" class="submenu-link" data-astro-cid-kavczoxm> All Items </a> <a href="/items/catalyst" class="submenu-link" data-astro-cid-kavczoxm> <img src="/icons/items/fertile-catalyst.png" alt="" class="submenu-icon" data-astro-cid-kavczoxm> <span data-astro-cid-kavczoxm>Catalyst</span> </a> <a href="/items/components" class="submenu-link" data-astro-cid-kavczoxm> <img src="/icons/items/large-wooden-gear.png" alt="" class="submenu-icon" data-astro-cid-kavczoxm> <span data-astro-cid-kavczoxm>Components</span> </a> <a href="/items/currency" class="submenu-link" data-astro-cid-kavczoxm> <img src="/icons/items/copper-coin.png" alt="" class="submenu-icon" data-astro-cid-kavczoxm> <span data-astro-cid-kavczoxm>Currency</span> </a> <a href="/items/fertilizer" class="submenu-link" data-astro-cid-kavczoxm> <img src="/icons/items/basic-fertilizer.png" alt="" class="submenu-icon" data-astro-cid-kavczoxm> <span data-astro-cid-kavczoxm>Fertilizer</span> </a> <a href="/items/fuel" class="submenu-link" data-astro-cid-kavczoxm> <img src="/icons/items/plank.png" alt="" class="submenu-icon" data-astro-cid-kavczoxm> <span data-astro-cid-kavczoxm>Fuel</span> </a> <a href="/items/herbs" class="submenu-link" data-astro-cid-k