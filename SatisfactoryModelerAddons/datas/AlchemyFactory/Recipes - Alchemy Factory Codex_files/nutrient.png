\":\"/device/nursery\",\"category\":\"raw material production\"},{\"id\":\"bank-portal\",\"name\":\"Bank Portal\",\"type\":\"device\",\"url\":\"/device/bank-portal\",\"category\":\"raw material production\"},{\"id\":\"dispatch-portal\",\"name\":\"Dispatch Portal\",\"type\":\"device\",\"url\":\"/device/dispatch-portal\",\"category\":\"raw material production\"},{\"id\":\"world-tree-nursery\",\"name\":\"World Tree Nursery\",\"type\":\"device\",\"url\":\"/device/world-tree-nursery\",\"category\":\"raw material production\"},{\"id\":\"grinder\",\"name\":\"Grinder\",\"type\":\"device\",\"url\":\"/device/grinder\",\"category\":\"automated processing\"},{\"id\":\"enhanced-grinder\",\"name\":\"Enhanced Grinder\",\"type\":\"device\",\"url\":\"/device/enhanced-grinder\",\"category\":\"automated processing\"},{\"id\":\"crucible\",\"name\":\"Crucible\",\"type\":\"device\",\"url\":\"/device/crucible\",\"category\":\"automated processing\"},{\"id\":\"stackable-crucible\",\"name\":\"Stackable Crucible\",\"type\":\"device\",\"url\":\"/device/stackable-crucible\",\"category\":\"automated processing\"},{\"id\":\"extractor\",\"name\":\"Extractor\",\"type\":\"device\",\"url\":\"/device/extractor\",\"category\":\"automated processing\"},{\"id\":\"thermal-extractor\",\"name\":\"Thermal Extractor\",\"type\":\"device\",\"url\":\"/device/thermal-extractor\",\"category\":\"automated processing\"},{\"id\":\"refiner\",\"name\":\"Refiner\",\"type\":\"device\",\"url\":\"/device/refiner\",\"category\":\"automated processing\"},{\"id\":\"knowledge-altar\",\"name\":\"Knowledge Altar\",\"type\":\"device\",\"url\":\"/device/knowledge-altar\",\"category\":\"automated processing\"},{\"id\":\"cauldron\",\"name\":\"Cauldron\",\"type\":\"device\",\"url\":\"/device/cauldron\",\"category\":\"automated processing\"},{\"id\":\"paradox-crucible\",\"name\":\"Paradox Crucible\",\"type\":\"device\",\"url\":\"/device/paradox-crucible\",\"category\":\"automated processing\"},{\"id\":\"processor\",\"name\":\"Processor\",\"type\":\"device\",\"url\":\"/device/processor\",\"category\":\"advanced crafting\"},{\"id\":\"kiln\",\"name\":\"Kiln\",\"type\":\"device\",\"url\":\"/device/kiln\",\"category\":\"advanced crafting\"},{\"id\":\"blender\",\"name\":\"Blender\",\"type\":\"device\",\"url\":\"/device/blender\",\"category\":\"advanced crafting\"},{\"id\":\"assembler\",\"name\":\"Assembler\",\"type\":\"device\",\"url\":\"/device/assembler\",\"category\":\"advanced crafting\"},{\"id\":\"alembic\",\"name\":\"Alembic\",\"type\":\"device\",\"url\":\"/device/alembic\",\"category\":\"advanced crafting\"},{\"id\":\"athanor\",\"name\":\"Athanor\",\"type\":\"device\",\"url\":\"/device/athanor\",\"category\":\"advanced crafting\"},{\"id\":\"advanced-blender\",\"name\":\"Advanced Blender\",\"type\":\"device\",\"url\":\"/device/advanced-blender\",\"category\":\"advanced crafting\"},{\"id\":\"advanced-assembler\",\"name\":\"Advanced Assembler\",\"type\":\"device\",\"url\":\"/device/advanced-assembler\",\"category\":\"advanced crafting\"},{\"id\":\"shaper\",\"name\":\"Shaper\",\"type\":\"device\",\"url\":\"/device/shaper\",\"category\":\"advanced crafting\"},{\"id\":\"advanced-shaper\",\"name\":\"Advanced Shaper\",\"type\":\"device\",\"url\":\"/device/advanced-shaper\",\"category\":\"advanced crafting\"},{\"id\":\"advanced-alembic\",\"name\":\"Advanced Alembic\",\"type\":\"device\",\"url\":\"/device/advanced-alembic\",\"category\":\"advanced crafting\"},{\"id\":\"advanced-athanor\",\"name\":\"Advanced Athanor\",\"type\":\"device\",\"url\":\"/device/advanced-athanor\",\"category\":\"advanced crafting\"},{\"id\":\"arcane-processor\",\"name\":\"Arcane Processor\",\"type\":\"device\",\"url\":\"/device/arcane-processor\",\"category\":\"advanced crafting\"},{\"id\":\"arcane-shaper\",\"name\":\"Arcane Shaper\",\"type\":\"device\",\"url\":\"/device/arcane-shaper\",\"category\":\"advanced crafting\"},{\"id\":\"stone-furnace\",\"name\":\"Stone Furnace\",\"type\":\"device\",\"url\":\"/device/stone-furnace\",\"category\":\"heating\"},{\"id\":\"blast-furnace\",\"name\":\"Blast Furnace\",\"type\":\"device\",\"url\":\"/device/blast-furnace\",\"category\":\"heating\"}]";

	// Parse the search index
	const searchIndex = JSON.parse(searchIndexJson);
	
	function performSearch(query) {
		if (!query || query.length < 2) {
			return [];
		}
		
		query = query.toLowerCase();
		
		// Score each item based on how well it matches
		const scored = searchIndex.map(item => {
			const name = item.name.toLowerCase();
			let score = 0;
			
			// Exact match gets highest score
			if (name === query) {
				score = 1000;
			}
			// Starts with query gets high score
			else if (name.startsWith(query)) {
				score = 100;
			}
			// Contains query gets medium score
			else if (name.includes(query)) {
				score = 50;
			}
			// No match gets 0
			else {
				return null;
			}
			
			// Boost items over recipes slightly
			if (item.type === 'item') {
				score += 5;
			}
			
			return { ...item, score };
		}).filter(item => item !== null);
		
		// Sort by score descending, then alphabetically
		scored.sort((a, b) => {
			if (a.score !== b.score) {
				return b.score - a.score;
			}
			return a.name.localeCompare(b.name);
		});
		
		// Return top 10 results
		return scored.slice(0, 10);
	}
	
	function renderResults(results) {
		const resultsContainer = document.getElementById('search-results');
		
		if (results.length === 0) {
			resultsContainer.style.display = 'none';
			return;
		}
		
		const html = results.map(result => `
			<div class="search-result-item" data-url="${result.url}">
				<div class="result-name">${result.name}</div>
			</div>
		`).join('');
		
		resultsContainer.innerHTML = html;
		resultsContainer.classList.add('show');
		
		// Add click handlers
		resultsContainer.querySelectorAll('.search-result-item').forEach(item => {
			item.addEventListener('click', () => {
				const url = item.dataset.url;
				window.location.href = url;
			});
		});
	}
	
	function hideResults() {
		document.getElementById('search-results').classList.remove('show');
	}
	
	// Wait for DOM to be ready
	document.addEventListener('DOMContentLoaded', () => {
		const searchInput = document.getElementById('search-input');
		const searchResults = document.getElementById('search-results');
		
		if (!searchInput) return;
		
		let searchTimeout;
		
		// Handle input
		searchInput.addEventListener('input', (e) => {
			clearTimeout(searchTimeout);
			const query = e.target.value.trim();
			
			if (query.length < 2) {
				hideResults();
				return;
			}
			
			// Debounce search
			searchTimeout = setTimeout(() => {
				const results = performSearch(query);
				renderResults(results);
			}, 150);
		});
		
		// Hide results when clicking outside
		document.addEventListener('click', (e) => {
			if (!searchInput.contains(e.target) && !searchResults.contains(e.target)) {
				hideResults();
			}
		});
		
		// Handle escape and enter keys
		searchInput.addEventListener('keydown', (e) => {
			if (e.key === 'Escape') {
				hideResults();
				searchInput.blur();
			} else if (e.key === 'Enter') {
				// Navigate to the first search result
				const firstResult = searchResults.querySelector('.search-result-item');
				if (firstResult) {
					const url = firstResult.dataset.url;
					window.location.href = url;
				}
			}
		});
	});
})();</script> </div> <div class="nav-right" data-astro-cid-kavczoxm> <button id="options-toggle" class="options-toggle" aria-label="Open options" data-astro-cid-6mhuqfzy> <span class="options-icon" data-astro-cid-6mhuqfzy>⚙️</span> <span class="options-text" data-astro-cid-6mhuqfzy>Options</span> </button>  <script type="module">const t=document.getElementById("options-toggle");t&&t.addEventListener("click",()=>{const o=document.getElementById("options-dialog");o&&o.classList.add("show")});</script> <!-- LanguageSelector / --> </div> </nav> <!-- Options Dialog --> <div id="options-dialog" class="options-dialog" data-astro-cid-kavczoxm> <div class="options-dialog-content" data-astro-cid-kavczoxm> <div class="options-dialog-header" data-astro-cid-kavczoxm> <h2 data-astro-cid-kavczoxm>Options</h2> <button class="close-options-dialog-btn" id="close-options-dialog" data-astro-cid-kavczoxm>×</button> </div> <div class="options-dialog-body" data-astro-cid-kavczoxm> <div class="option-item" data-astro-cid-kavczoxm> <label for="dark-mode-toggle" data-astro-cid-kavczoxm> <span class="option-icon" data-astro-cid-kavczoxm>🌙</span> <span data-astro-cid-kavczoxm>Dark Mode</span> </label> <label class="toggle-switch" data-astro-cid-kavczoxm> <input type="checkbox" id="dark-mode-toggle" data-astro-cid-kavczoxm> <span class="toggle-slider" data-astro-cid-kavczoxm></span> </label> </div> <div class="option-item" style="flex-direction: column; align-items: stretch;" data-astro-cid-kavczoxm> <div style="display: flex; justify-content: space-between; align-items: center;" data-astro-cid-kavczoxm> <label for="currency-display-select" data-astro-cid-kavczoxm> <span class="option-icon" data-astro-cid-kavczoxm>💰</span> <span data-astro-cid-kavczoxm>Currency Display</span> </label> <select id="currency-display-select" class="option-select" data-astro-cid-kavczoxm> <option value="copper" data-astro-cid-kavczoxm>Always Copper</option> <option value="decimals" data-astro-cid-kavczoxm>Copper/Si